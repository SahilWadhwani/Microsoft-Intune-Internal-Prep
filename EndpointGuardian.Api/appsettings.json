{
  "ConnectionStrings": {
    "EndpointGuardianDb": "Data Source=endpointguardian.db"
  },
  "CompliancePolicy": {
    "MinimumOsVersion": 13,
    "RequireEncryption": true,
    "RequirePassword": true,
    "RequireDefender": true,
    "MaxCheckInAgeHours": 72
  },
   "ScheduledCompliance": {
    "Enabled": true,
    "IntervalSeconds": 60,
    "MaxDevicesPerRun": 25,
    "ReevaluateAfterMinutes": 60,
    "EvaluateOnlyStaleOrUnknownDevices": true
  }

}